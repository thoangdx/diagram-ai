{
  "name": "@dbdiagram/parser",
  "version": "1.0.0",
  "private": true,
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "build:watch": "tsc -p tsconfig.json --watch",
    "lint": "eslint src --ext .ts",
    "test": "ts-node --project tsconfig.test.json test/parser.test.ts && ts-node --project tsconfig.test.json test/graph-builder.test.ts && ts-node --project tsconfig.test.json test/layout.test.ts",
    "test:unit": "jest"
  },
  "dependencies": {
    "@dbdiagram/shared": "*",
    "dagre": "^0.8.5"
  },
  "devDependencies": {
    "@types/dagre": "^0.7.3",
    "@types/jest": "^29.5.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.0",
    "ts-node": "^10.9.0"
  }
}
